    "name": {
      "description": "Remington GAIL (SIL)"
    },
    "description": {
      "description": "<p>This keyboard is an implementation of the Remington-GAIL typewriter\nlayout for inputting Unicode-compliant Devanagari. The layout was\ndesigned for Hindi input, but may suffice for other Devanagari script\nbased languages. It faithfully implements the default and Shift keys of\nthe legacy Remington-GAIL layout on a standard QWERTY keyboard. It also\nprovides a number of additional characters from the APS Saral layout\nusing the AltGr (Right Alt) and AltGR+Shift key modifiers.</p>"
    },
    "version": {
      "description": "1.1"
    }
  },
